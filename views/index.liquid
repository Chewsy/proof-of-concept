{% render 'partials/head.liquid' %}


<section class="details">
{% for house in houses limit:1 %}
  <div class="img-interacties">
    <button class="interactie">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48"><path d="M36 31.3a6 6 0 00-4.81 2.42l-13.51-7.8a5.92 5.92 0 00.08-3.58l13.7-7.91a6 6 0 10-1.33-2.69l-13.89 8a6 6 0 10-.2 8.68l14 8.09A6 6 0 1036 31.3zm0-23.78a3 3 0 11-3 3 3 3 0 013-3zM12 27a3 3 0 113-3 3 3 0 01-3 3zm24 13.3a3 3 0 113-3 3 3 0 01-3 3z"></path></svg>
    </button>
<button class="interactie {% if favorieteHuizenIds contains house.id %}favoriet{% endif %}" id="favorietKnop" data-house-id="{{ house.id }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48">
        <path class="icon-outline" d="M39 9.86A10.17 10.17 0 0032 7a9.9 9.9 0 00-6 2 10.1 10.1 0 00-2 2 10.1 10.1 0 00-2-2 9.91 9.91 0 00-12 0 9.9 9.9 0 00-4 8c0 15 16 24 18 24s18-9 18-24a10 10 0 00-3-7.14zm-15 28a29.61 29.61 0 01-12.72-12.1A18.77 18.77 0 019 17a7 7 0 0113.41-2.81c.06.14.11.29.17.44a1.49 1.49 0 002.82 0c.05-.15.11-.3.17-.44A7 7 0 0139 17a18.77 18.77 0 01-2.28 8.81A29.61 29.61 0 0124 37.91z"></path>
        <path class="icon-filled" d="M39 9.86A10.17 10.17 0 0032 7a9.9 9.9 0 00-6 2 10.1 10.1 0 00-2 2 10.1 10.1 0 00-2-2 9.91 9.91 0 00-12 0 9.9 9.9 0 00-4 8c0 15 16 24 18 24s18-9 18-24a10 10 0 00-3-7.14z"></path>
      </svg>
  </button>
  </div>

  <img src="https://fdnd-agency.directus.app/assets/{{ house.poster_image }}.png"> 

  <div class="details-container">
    <div class="straat">  <h1>{{ house.street }}</h1>
</div>
    <div class="postcode-stad-buurt">
    <span>{{ house.postal_code }}</span>
        <span>{{ house.city }}</span>
    <a href="https://www.funda.nl/informatie/almere/europakwartier-oost-brt">Europakwartier Oost (brt)</a>
</div>

    <div class="prijs">
      <span>{{ house.customPrice }}</span>
    </div> 

    <div class="labels-container">
      <div class="label">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48" class="mr-1 text-neutral-40"><path d="M38.5 32.25v-16.5a5 5 0 10-6.25-6.25h-16.5a5 5 0 10-6.25 6.25v16.5a5 5 0 106.25 6.25h16.5a5 5 0 106.25-6.25zm-6.25 3.25h-16.5a5 5 0 00-3.25-3.25v-16.5a5 5 0 003.25-3.25h16.5a5 5 0 003.25 3.25v16.5a5 5 0 00-3.25 3.25zM37 9a2 2 0 11-2 2 2 2 0 012-2zM11 9a2 2 0 11-2 2 2 2 0 012-2zm0 30a2 2 0 112-2 2 2 0 01-2 2zm26 0a2 2 0 112-2 2 2 0 01-2 2z"></path></svg>
      <span>{{ house.m2 }}</span>
      </div>

      <div class="label">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48" class="mr-1 text-neutral-40"><path d="M11 20l-3.999 5.999h33.998L37 20h3l3.999 5.999L44 26v9.5a1.5 1.5 0 01-1.5 1.5H39v1.5a1.5 1.5 0 01-3 0V37H12v1.5a1.5 1.5 0 01-3 0V37H5.5A1.5 1.5 0 014 35.5V26l.001-.001L8 20h3zm30 9H7v5h34v-5zM38.5 8A1.5 1.5 0 0140 9.5V20l-9-.001V21.5a1.5 1.5 0 01-1.5 1.5h-11a1.5 1.5 0 01-1.5-1.5v-1.501L8 20V9.5A1.5 1.5 0 019.5 8h29zM28 17h-8v3h8v-3zm9-6H11v5.999h6V15.5a1.5 1.5 0 011.5-1.5h11a1.5 1.5 0 011.5 1.5v1.499h6V11z"></path></svg>
        <span>{{ house.rooms }}</span>
      </div>

      <div class="label">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48" class="mr-1 text-neutral-40"><path d="M23.675 12.891l-6.852 13.063 7.032 1.628.492 7.872 7.31-13.373-7.51-1.63-.472-7.56zm2.45-8.897L27 18l6.274 1.362c1.62.351 2.295 1.818 1.5 3.274l-11.82 21.618c-.529.968-1.01.853-1.079-.248L21 30l-5.714-1.323c-1.612-.373-2.3-1.868-1.529-3.337L25.073 3.767c.511-.975.983-.874 1.052.227z"></path></svg>        <span>A++</span>
      </div>
    </div>
    <div class="maandlasten">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" role="presentation" viewBox="0 0 48 48"><circle cx="16" cy="22" r="2"></circle><circle cx="24" cy="22" r="2"></circle><circle cx="32" cy="22" r="2"></circle><circle cx="16" cy="29" r="2"></circle><circle cx="24" cy="29" r="2"></circle><circle cx="32" cy="29" r="2"></circle><circle cx="16" cy="36" r="2"></circle><circle cx="24" cy="36" r="2"></circle><circle cx="32" cy="36" r="2"></circle><rect width="20" height="8" x="14" y="9" rx="1" ry="1"></rect><path d="M36 6a1 1 0 011 1v34a1 1 0 01-1 1H12a1 1 0 01-1-1V7a1 1 0 011-1h24m0-3H12a4 4 0 00-4 4v34a4 4 0 004 4h24a4 4 0 004-4V7a4 4 0 00-4-4z"></path></svg>
        <span>Wat worden mijn maandlasten?</span>
    </div>
    <div class="map">
      <div class="size-[3.75rem] overflow-hidden rounded-md border border-neutral-20 motion-safe:transition-transform motion-safe:duration-100 motion-safe:ease-in-out-soft motion-safe:active:scale-95 md:size-[4.25rem]"><img src="https://nuxt.fstatic.nl/716adbe2a1f60dad/detail/_nuxt/map.Bc4Msx4Z.svg" aria-hidden="true" class="size-full object-cover motion-safe:transition-transform motion-safe:duration-500 motion-safe:ease-in-out-soft motion-safe:hover:scale-120" height="68" width="68"></div>
      <a href="#">Kaart</a>
    </div>
  </section>

  <hr>

<section class="omschrijving">
  <h2>Omschrijving</h2>
  <p>{{ house.description }}</p>
</section>

<section class="kenmerken">
  <h2>Kenmerken</h2>
  <div class="kenmerk-container">
    <div class="kenmerken-titel">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48"><path fill-rule="evenodd" d="M20.1 41.8a1.5 1.5 0 01-2.1-2.1l1.8-1.8 2 2.1-1.7 1.8zM17 36.5l-1 1a1.5 1.5 0 01-2.2-2l1.1-1.1.7-.8a1.5 1.5 0 012.1 2.2l-.7.7zm-1.4-7.1L14 31l-.5.5-.7.7-1 1v.1a1.5 1.5 0 01-2.2-2.1l1.8-1.8.5-.5 1.6-1.6 1.4-1.4a1.5 1.5 0 012.1 2l-1.4 1.5zm18.8 8.1l.8-1.2c.3-.6.4-1.1.5-1.7a4.5 4.5 0 003.8-2.6c.7-1.5.5-3.3-.6-4.7l6-6a1.5 1.5 0 00-2-2.1l-6 6-4-4-6.7-6.6-1.4-1.5.4-.3a1.5 1.5 0 00-2.2-2.1l-.3.3-.7.7-.7.7-.2.2-.5.5-.4.4-.3.3-1.8 1.8a1.5 1.5 0 01-2.1-2.1l1.8-1.8.4-.5h.1l.1-.2.6-.5L20.5 9l.7-.7.7-.7 1-1 .5-.4c.5-.2 1.2-.1 1.7.3L27.5 9l1.1 1c.6.6 1.5.6 2.1 0l1-1 .4-.4c.6-.5.6-1.5 0-2v-.1c-.6-.6-1.5-.6-2 0l-.4.4-2.5-2.5s-.4-.4 0 0a4.6 4.6 0 00-6.4 0l-1 1-1.5 1.5-1-1a1.5 1.5 0 00-2.1 2l1 1.1-2.4 2.5a4.5 4.5 0 001.2 7.2c1.7.8 3.7.5 5.1-.9l2.5-2.4 1.4 1.4 6.7 6.7 2.7 2.7 1.2 1.2 1.8 1.7.3.5c.2.5.1 1.2-.3 1.7a1.5 1.5 0 01-2.1 0l-1.8-1.8-1.2-1.2-2-2a1.5 1.5 0 10-2.1 2.1l2 2 1.2 1.2 1.7 1.8c.2.1.3.3.3.4.3.6.2 1.3-.3 1.7a1.5 1.5 0 01-2 0l-1.9-1.8-1.2-1.2-2-2a1.5 1.5 0 00-2 2.2l2 2 1.1 1.2 1.8 1.7.3.5c.2.5.2 1.2-.3 1.7-.5.4-1.2.5-1.7.2l-.4-.2L24 38l-1.2-1.2-1-1-.7-.8c0-.7-.2-1.4-.5-2.1l-.8-1.3-1.3-.8.6-.6.6-.8a4.5 4.5 0 00-7-5.6l-1.4 1.5-6.7-6.8a1.5 1.5 0 00-2.2 2.2l6.8 6.7L7.4 29a4.5 4.5 0 003 7.6 4.5 4.5 0 004.2 4.3 4.5 4.5 0 002.5 3.8c1.7.8 3.7.5 5.1-.9L24 42a4.5 4.5 0 007.3-3.3 4.5 4.5 0 003-1.3z" clip-rule="evenodd"></path></svg>
      <h3>Overdracht</h3>
    </div>
    <span class="bold" >Aangeboden sinds</span>
    <span>{{ house.customDate }}</span>
    <hr>
    <span class="bold">Aanvaarding</span>
    <span>{{ house.customAanvaarding }}</span>
    <hr>
    <span class="bold">Vraagprijs</span>
    <span>{{ house.customPrice }}</span>
    <hr>
    <span class="bold">Vraagprijs per m²</span>
    <span>{{ house.customVraagprijsPerM }}</span>
    <hr>
    <span class="bold">Status</span>
    <span>{{ house.customStatus }}</span>

</div>

  <div class="kenmerk-container">
    <div class="kenmerken-titel">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48"><path d="M42.5 28.51v-18A1.5 1.5 0 0041 9H24a1.49 1.49 0 00-1.38.92 1.4 1.4 0 00-.12.58V18h-7a1.5 1.5 0 00-1.38.92 1.4 1.4 0 00-.12.58V27H7a1.5 1.5 0 00-1.38.92 1.4 1.4 0 00-.12.58v9A1.5 1.5 0 007 39h34a1.5 1.5 0 001.5-1.5zM8.5 30h14v6h-14zm31-9v6H34v-6zM24 21h7v6H17v-6zm1.52 9h14v6h-14zm0-18h14v6h-14z"></path></svg>      <h3>Bouw</h3>
    </div>
    <span class="bold" >Bouwjaar</span>
    <span>{{ house.customBuildYear }}</span>
    <hr>
    <span class="bold">Soort woonhuis</span>
    <span>{{ house.customHouseType }}</span>
    <hr>
    <span class="bold">Soort bouw</span>
    <span>{{ house.customBuildType }}</span>
    <hr>
    <span class="bold">Soort dak</span>
    <span>{{ house.customDakType }}</span>
</div>

{% comment %} Andere kenmerken overgeslagen i.v.m geen data en vaak genoeg mock-data gemaakt {% endcomment %}

  <div class="kenmerk-container">
    <div class="kenmerken-titel">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48"><path d="M23.675 12.891l-6.852 13.063 7.032 1.628.492 7.872 7.31-13.373-7.51-1.63-.472-7.56zm2.45-8.897L27 18l6.274 1.362c1.62.351 2.295 1.818 1.5 3.274l-11.82 21.618c-.529.968-1.01.853-1.079-.248L21 30l-5.714-1.323c-1.612-.373-2.3-1.868-1.529-3.337L25.073 3.767c.511-.975.983-.874 1.052.227z"></path></svg>
    <h3>Energie</h3>
    </div>
    <span class="bold" >Energielabel</span>
    <div class="kenmerken-titel">
    <span class="energielabel">{{ house.customEnergielabel }}</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="var(--blauw)" role="presentation" viewBox="0 0 48 48" aria-label="Lees meer over energielabels"><rect width="3" height="17" x="22.5" y="18" rx="1.5" ry="1.5"></rect><path d="M24 16a1.5 1.5 0 000-3 1.5 1.5 0 000 3z"></path><path d="M24 4a20 20 0 1020 20A20 20 0 0024 4zm0 37a17 17 0 1117-17 17 17 0 01-17 17z"></path></svg>
    </div>
    <hr>
    <span class="bold">Isolatie</span>
    <span>Volledig geïsoleerd</span>
    <hr>
    <span class="bold">Verwarming</span>
    <span>Stadsverwarming en gehele vloerverwarming</span>
    <hr>
    <span class="bold">Warm water</span>
    <span>Stadsverwarming</span>
</div>

</section>

<section class="populariteit">
    <h2>Populariteit</h2>
    <div class="populariteit-container">

      <div class="populariteit-stat">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48" class="inline align-middle text-neutral-50"><path d="M23.713 16a8 8 0 110 16 8 8 0 010-16zm0 3a5 5 0 100 10 5 5 0 000-10zm0-9C12.58 10 4.253 18.728 1.965 21.402a3.979 3.979 0 000 5.196C4.252 29.272 12.58 38 23.713 38c11.133 0 19.46-8.728 21.748-11.402a3.979 3.979 0 000-5.196C43.173 18.728 34.846 10 23.713 10m0 3c9.887 0 17.451 7.993 19.468 10.352a.992.992 0 010 1.296C41.164 27.007 33.601 35 23.713 35c-9.887 0-17.45-7.993-19.468-10.352a.992.992 0 010-1.296C6.262 20.993 13.826 13 23.713 13"></path></svg>
      <span class="bold">{{ house.randomBekeken }}</span>
      <span>Bekeken</span>
      </div>

      <div class="populariteit-stat">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48" class="inline align-middle text-neutral-50"><path d="M39 9.86A10.17 10.17 0 0032 7a9.9 9.9 0 00-6 2 10.1 10.1 0 00-2 2 10.1 10.1 0 00-2-2 9.91 9.91 0 00-12 0 9.9 9.9 0 00-4 8c0 15 16 24 18 24s18-9 18-24a10 10 0 00-3-7.14zm-15 28a29.61 29.61 0 01-12.72-12.1A18.77 18.77 0 019 17a7 7 0 0113.41-2.81c.06.14.11.29.17.44a1.49 1.49 0 002.82 0c.05-.15.11-.3.17-.44A7 7 0 0139 17a18.77 18.77 0 01-2.28 8.81A29.61 29.61 0 0124 37.91z"></path></svg>
      <span class="bold">{{ house.randomBewaard }}</span>
      <span>Bewaard</span>
      </div>

      <div class="populariteit-stat">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" role="presentation" viewBox="0 0 48 48" class="inline align-middle text-neutral-50"><path d="M42 38.41V12.5a1.5 1.5 0 00-1.5-1.5h-7V9.5a1.5 1.5 0 00-3 0V11h-13V9.5a1.5 1.5 0 00-3 0V11h-7A1.5 1.5 0 006 12.5v26A1.5 1.5 0 007.5 40h33a1.5 1.5 0 001.5-1.5v-.09zM16 17a1.5 1.5 0 001.5-1.5V14h13v1.5a1.5 1.5 0 003 0V14H39v23H9V14h5.5v1.5A1.5 1.5 0 0016 17z"></path><circle cx="16" cy="23" r="2"></circle><circle cx="16" cy="31" r="2"></circle><circle cx="24.01" cy="23" r="2"></circle><circle cx="24.01" cy="31" r="2"></circle><circle cx="32" cy="23" r="2"></circle><circle cx="32" cy="31" r="2"></circle></svg>      
      <span class="bold">{{ house.listed_date }}</span>
      <span>Op Funda</span>
      </div>

      </div>
    </div>
</section>
{% endfor %}
{% render 'partials/foot.liquid' %}
